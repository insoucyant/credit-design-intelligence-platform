# Why does this file exist?
# .env.example is used to provide a template for environment variables that are required for the application to run. It serves as a reference for developers to know which environment variables they need to set in their own .env file. 
# The .env file should not be committed to version control, as it may contain sensitive information such as API keys, database credentials, and other secrets. 
# Instead, developers should create their own .env file based on the .env.example template and fill in the necessary values.
# You never commit .env. It contains secret. Instead you commit .env.example, which is a template for the .env file. 
# Developers can copy .env.example to .env and fill in the necessary values without exposing sensitive information in version control.

#############################################################
# Environment
#############################################################

Environment=development

#############################################################
# Project
#############################################################

PROJECT_NAME=credit-decision-intelligence-platform

#############################################################
# Logging
#############################################################

LOG_LEVEL=INFO

#############################################################
# API
#############################################################

API_HOST=0.0.0.0
API_PORT=8000

#############################################################
# MLflow
#############################################################

MLFLOW_TRACKING_URL=http://localhost:5000

#############################################################
# Data
#############################################################

DATA_DIR=data
#############################################################
# Model
#############################################################

MODEL_NAME=lightgbm
MODEL_VERSION=latest

#############################################################
# Monitoring
#############################################################

ENABLE_MONITORING-true

#############################################################
# Random Seed
#############################################################

RANDOM_SEED=42